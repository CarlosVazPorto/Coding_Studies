-- Consulta por professor que não está atuando no momento
SELECT * FROM HistoricoEmprego
WHERE cargo = 'Professor'
AND datatermino NOTNULL;

-- Cosulta por oftlamologista ou dermatologista
SELECT * FROM HistoricoEmprego
WHERE cargo = 'Oftalmologista' 
OR cargo = 'Dermatologista';

-- Cosulta por oftlamologista, dermatologista ou professor
SELECT * FROM HistoricoEmprego
WHERE cargo IN ('Oftalmologista', 'Dermatologista', 'Professor');

-- Cosulta por colaborador que não seja oftlamologista, dermatologista ou professor
SELECT * FROM HistoricoEmprego
WHERE cargo NOT IN ('Oftalmologista', 'Dermatologista', 'Professor');

-- Consulta colaboradores cadastrados que estão desempregados no momento
SELECT COUNT(*)
FROM HistoricoEmprego
WHERE datatermino NOTNULL;

-- Consulta o número de colaboradores existentes em cada cargo (profissões mais cadastradas no banco de dados)
SELECT cargo, COUNT(*) AS quantidade
FROM HistoricoEmprego
GROUP BY cargo
HAVING quantidade >= 2;
