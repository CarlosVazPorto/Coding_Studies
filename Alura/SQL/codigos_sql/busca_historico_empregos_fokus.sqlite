-- Consulta qual o intervalo de tempo de duração de cada contrato
SELECT id_colaborador, JULIANDAY(datatermino) - JULIANDAY(datacontratacao) AS duracao
FROM HistoricoEmprego
WHERE datatermino IS NOT NULL
ORDER BY duracao ASC;

-- Consulta que retorna os valores salariais categorizados conforme definido pelo usuário 
-- Observação: não esquecer da vírgula após o último campo do SELECT
SELECT id_colaborador, cargo, salario,
CASE 
WHEN salario < 5000 then 'Baixo'
when salario BETWEEN 5000 AND 10000 THEN 'Médio'
ELSE 'Alto'
end AS 'Categoria salarial'
FROM HistoricoEmprego
ORDER BY salario;

