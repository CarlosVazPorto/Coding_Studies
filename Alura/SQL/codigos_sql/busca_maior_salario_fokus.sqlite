-- Consulta SQL que retorna todos os colaboradores da Fokus
SELECT * FROM Colaboradores;

-- Consulta SQL que retorna os 5 colaboradores com maior salário e que estão em atividade
SELECT * FROM HistoricoEmprego
WHERE datatermino IS NULL
ORDER BY salario DESC
LIMIT 5;

-- Consulta SQL que retorna os 5 colaboradores com maior salário que já saíram da empresa
SELECT * FROM HistoricoEmprego
WHERE datatermino NOT NULL
ORDER BY salario DESC
LIMIT 5;
