-- Consulta geral
SELECT *
FROM Treinamento;

--Consulta o número de cursos de cada instituição
SELECT instituicao, COUNT(curso)
FROM Treinamento
GROUP BY instituicao;

--Consulta as instituições que possuem mais de 2 cursos
SELECT instituicao, COUNT(curso)
FROM Treinamento
GROUP BY instituicao
HAVING COUNT(curso) > 2;
