-- Consulta geral da tabela Licenças
SELECT *
FROM Licencas;

-- Consulta quantos colaboradores tiraram férias
SELECT COUNT(*)
FROM Licencas
WHERE tipolicenca = 'férias';

-- Consulta que retorna o ano e o mês da DataInicio para cada colaborador
SELECT id_colaborador, STRFTIME('%Y/%m', datainicio) AS 'Data de início'
FROM Licencas;
